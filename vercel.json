{
  "version": 2,
  "installCommand": "cd Frontend && npm install",
  "buildCommand": "cd Frontend && npm run build -- --outDir ../public",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
